        "/usr/local/include/**",
        "/usr/include/**",
        "/usr/include/eigen3"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "/opt/ros/humble/include",
          "/home/tom/ocs2_ws/install",
          "/home/tom/ocs2_ws/src",
          "/usr/local/include",
          "/usr/include",
          "/usr/include/eigen3"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}
