centroidalModelType             1      // 0: FullCentroidalDynamics, 1: Single Rigid Body Dynamics

humanoid_interface
{
  verbose                               false  // show the loaded parameters
  useAnalyticalGradientsDynamics        false
  useAnalyticalGradientsConstraints     false
}

model_settings
{
  positionErrorGain             45.0 ; 20.0
  phaseTransitionStanceTime     0.70

  verboseCppAd                  false
  recompileLibrariesCppAd       true
  modelFolderCppAd              /tmp/ocs2
}

swing_trajectory_config
{
  liftOffVelocity               0.020
  touchDownVelocity            -0.002
  swingHeight                   0.048
  swingTimeScale                0.42
}

; Multiple_Shooting SQP settings
sqp
{
  nThreads                              4
  dt                                    0.015
  sqpIteration                          1
  deltaTol                              1e-4
  g_max                                 1e-2
  g_min                                 1e-6
  inequalityConstraintMu                0.1
  inequalityConstraintDelta             5.0
  projectStateInputEqualityConstraints  true
  printSolverStatistics                 false
  printSolverStatus                     false
  printLinesearch                       false
  useFeedbackPolicy                     false
  integratorType                        RK2
  threadPriority                        50
}

; Multiple_Shooting IPM settings
ipm
{
  nThreads                              3
  dt                                    0.015
  ipmIteration                          1
  deltaTol                              1e-4
  g_max                                 10.0
  g_min                                 1e-6
  computeLagrangeMultipliers            true
  printSolverStatistics                 true
  printSolverStatus                     false
  printLinesearch                       false
  useFeedbackPolicy                     false
  integratorType                        RK2
  threadPriority                        50

  initialBarrierParameter               1e-4
  targetBarrierParameter                1e-4
  barrierLinearDecreaseFactor           0.2
  barrierSuperlinearDecreasePower       1.5
  barrierReductionCostTol               1e-3
  barrierReductionConstraintTol         1e-3

  fractionToBoundaryMargin              0.995
  usePrimalStepSizeForDual              false

  initialSlackLowerBound                1e-4
  initialDualLowerBound                 1e-4
  initialSlackMarginRate                1e-2
  initialDualMarginRate                 1e-2
}

; Rollout settings
rollout
{
  AbsTolODE                       1e-5
  RelTolODE                       1e-3
  timeStep                        0.015
  integratorType                  ODE45
  maxNumStepsPerSecond            10000
  checkNumericalStability         false
}

mpc
{
  timeHorizon                     1.5  ; [s]
  solutionTimeWindow              -1   ; maximum [s]
  coldStart                       false

  debugPrint                      false

  mpcDesiredFrequency             100  ; [Hz]
  mrtDesiredFrequency             1000 ; [Hz] Useless
}

initialState
{
   ;; Normalized Centroidal Momentum: [linear, angular] ;;
   (0,0)  0.0     ; vcom_x
   (1,0)  0.0     ; vcom_y
   (2,0)  0.0     ; vcom_z
   (3,0)  0.0     ; L_x / robotMass
   (4,0)  0.0     ; L_y / robotMass
   (5,0)  0.0     ; L_z / robotMass

   ;; Base Pose: [position, orientation] ;;
   (6,0)  0.0     ; p_base_x
   (7,0)  0.0     ; p_base_y
   (8,0)  0.759   ; p_base_z
   (9,0)  0.0     ; theta_base_z
   (10,0) 0.0     ; theta_base_y
   (11,0) 0.0     ; theta_base_x

   ;; Leg Joint Positions ;;
   (12,0) -0.30   ; left_hip_pitch_joint
   (13,0)  0.00   ; left_hip_roll_joint
   (14,0)  0.00   ; left_hip_yaw_joint
   (15,0)  0.70   ; left_knee_joint
   (16,0) -0.40   ; left_ankle_pitch_joint
   (17,0)  0.00   ; left_ankle_roll_joint
   (18,0) -0.30   ; right_hip_pitch_joint
   (19,0)  0.00   ; right_hip_roll_joint
   (20,0)  0.00   ; right_hip_yaw_joint
   (21,0)  0.70   ; right_knee_joint
   (22,0) -0.40   ; right_ankle_pitch_joint
   (23,0)  0.00   ; right_ankle_roll_joint
}

; standard state weight matrix
Q
{
  scaling 1e+0

  ;; Normalized Centroidal Momentum: [linear, angular] ;;
  (0,0)   10.0     ; vcom_x
  (1,1)   12.0     ; vcom_y
  (2,2)   12.0     ; vcom_z
  (3,3)   8.0      ; L_x / robotMass
  (4,4)   8.0      ; L_y / robotMass
  (5,5)   8.0      ; L_z / robotMass

  ;; Base Pose: [position, orientation] ;;
  (6,6)   100.0    ; p_base_x
  (7,7)   180.0    ; p_base_y
  (8,8)   2500.0   ; p_base_z
  (9,9)   180.0    ; theta_base_z
  (10,10) 3200.0   ; theta_base_y
  (11,11) 3200.0   ; theta_base_x

  ;; Leg Joint Positions ;;
  (12,12) 220.0    ; left_hip_pitch_joint
  (13,13) 380.0    ; left_hip_roll_joint
  (14,14) 260.0    ; left_hip_yaw_joint
  (15,15) 340.0    ; left_knee_joint
  (16,16) 340.0    ; left_ankle_pitch_joint
  (17,17) 150.0    ; left_ankle_roll_joint

  (18,18) 220.0    ; right_hip_pitch_joint
  (19,19) 380.0    ; right_hip_roll_joint
  (20,20) 260.0    ; right_hip_yaw_joint
  (21,21) 340.0    ; right_knee_joint
  (22,22) 340.0    ; right_ankle_pitch_joint
  (23,23) 150.0    ; right_ankle_roll_joint
}

; control weight matrix
R
{
  scaling 1e-3

  ;; Feet Contact Forces: [LF, RF, LH, RH] ;;
  (0,0)   2.5       ; x
  (1,1)   2.0       ; y
  (2,2)   5.5       ; z
  (3,3)   2.5       ; x
  (4,4)   2.0       ; y
  (5,5)   5.5       ; z
  (6,6)   2.5       ; x
  (7,7)   2.0       ; y
  (8,8)   5.5       ; z
  (9,9)   2.5       ; x
  (10,10) 2.0       ; y
  (11,11) 5.5       ; z

  ;; foot velocity relative to base: [LF, LH, RF, RH] (uses the Jacobian at nominal configuration) ;;
  (12,12) 3200.0    ; x
  (13,13) 4200.0    ; y
  (14,14) 4200.0    ; z
  (15,15) 3200.0    ; x
  (16,16) 4200.0    ; y
  (17,17) 4200.0    ; z
  (18,18) 3200.0    ; x
  (19,19) 4200.0    ; y
  (20,20) 4200.0    ; z
  (21,21) 3200.0    ; x
  (22,22) 4200.0    ; y
  (23,23) 4200.0    ; z
}

frictionConeSoftConstraint
{
  frictionCoefficient    0.7

  ; relaxed log barrier parameters
  mu                     0.1
  delta                  5.0
}

jointSoftLimit
{
  enabled           true

  ; hip roll joints
  hipRollMin       -0.08
  hipRollMax        0.08

  ; hip yaw joints
  hipYawMin        -0.12
  hipYawMax         0.12

  ; knee joints
  kneeMin           0.30
  kneeMax           1.05

  ; ankle roll joints
  ankleRollMin     -0.08
  ankleRollMax      0.08

  ; squared hinge weights
  hipRollWeight     260.0
  hipYawWeight      220.0
  kneeWeight        300.0
  ankleRollWeight   140.0
  delta             0.02
}

selfCollision
{
  activate  false

  ; Self Collision raw object pairs
  collisionObjectPairs
  {
  }

  ; Self Collision pairs
  collisionLinkPairs
  {
  }

  minimumDistance  0.03

  ; relaxed log barrier parameters
  mu      1e-2
  delta   1e-3
}

; Whole body control
torqueLimitsTask
{
  (0,0)  150.0     ; hip_pitch
  (1,0)  150.0     ; hip_roll
  (2,0)  300.0     ; hip_yaw
  (3,0)  230.0     ; knee
  (4,0)  125.0     ; ankle_pitch
  (5,0)   60.0     ; ankle_roll
}

frictionConeTask
{
  frictionCoefficient    0.7
}

swingLegTask
{
    kp                   135
    kd                   10
}

baseAngularTask
{
    kp                   30
    kd                   3
}

weight
{
    swingLeg        55
    baseAccel       2
    contactForce    6
}

; State Estimation
kalmanFilter
{
    footRadius                  -0.013
    imuProcessNoisePosition     0.02
    imuProcessNoiseVelocity     0.02
    footProcessNoisePosition    0.5
    footSensorNoisePosition     0.5
    footSensorNoiseVelocity     0.05
    footHeightSensorNoise       0.01
}

contactForceEsimation
{
   cutoffFrequency    250
   contactThreshold   75
}

; 机器人Imu装歪了一点，或机器人有向某个方向行走的固定偏差，可以微调这里
imuBias
{
   yaw    0.0 ; useless for relative yaw control
   pitch  -0.007
   roll   0.0
}
